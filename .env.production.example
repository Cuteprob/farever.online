# BloodMoney 生产环境配置模板
# 复制此文件为 .env.production 并填入实际值

# 数据库配置
TURSO_DATABASE_URL="https://your-database-url.turso.io"
TURSO_DATABASE_AUTH_TOKEN="your-turso-auth-token-here"

# 项目配置
PROJECT_ID="bloodmoney-info"
PROJECT_NAME="BloodMoney"
PROJECT_EMAIL="support@bloodmoney.info"
NEXT_PUBLIC_WEB_URL="https://bloodmoney.info"

# 安全提醒：
# 1. 永远不要将包含真实凭据的 .env 文件提交到 git
# 2. 使用强随机的认证令牌
# 3. 定期轮换密钥和令牌
# 4. 确保生产环境使用 HTTPS
